#!/usr/bin/env bash
set -euo pipefail
source "${SQ_ENGINE_DIR}/lib/progress.sh"
source "${SQ_ENGINE_DIR}/lib/conditions.sh"
current=$(get_current_quest)
[[ "$current" == "done" ]] && exit 0
if check_quest_conditions "$current"; then
  mark_quest_complete "$current"
  cat "${SQ_THEME_DIR}/narrative/quest-${current}-complete.txt"
  next=$(get_current_quest)
  if [[ "$next" == "08" && "$current" == "07" ]]; then cp "${SQ_THEME_DIR}/narrative/sages_challenge.txt" "$HOME/sages_challenge.txt"; fi
  [[ "$next" != "done" ]] && cat "${SQ_THEME_DIR}/narrative/quest-${next}-intro.txt" || cat "${SQ_THEME_DIR}/narrative/finale.txt"
fi
